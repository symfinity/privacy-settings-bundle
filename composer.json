{
    "name": "symfinity/privacy-settings-bundle",
    "description": "Strict privacy category settings, consent capture, and form-tier consent UI for Symfony",
    "type": "symfony-bundle",
    "license": "MIT",
    "homepage": "https://github.com/symfinity/privacy-settings-bundle",
    "support": {
        "issues": "https://github.com/symfinity/privacy-settings-bundle/issues",
        "source": "https://github.com/symfinity/privacy-settings-bundle",
        "docs": "https://github.com/symfinity/privacy-settings-bundle/tree/main/docs"
    },
    "authors": [
        {
            "name": "Symfinity",
            "email": "dev@symfinity.net",
            "homepage": "https://symfinity.net/"
        }
    ],
    "keywords": [
        "symfony",
        "symfony-bundle",
        "privacy",
        "consent",
        "gdpr",
        "cookie",
        "ux-blocks",
        "twig-components"
    ],
    "require": {
        "php": ">=8.2",
        "symfinity/ux-blocks-form": "^0.1",
        "symfony/asset-mapper": "^7.4||^8.0",
        "symfony/config": "^7.4||^8.0",
        "symfony/dependency-injection": "^7.4||^8.0",
        "symfony/framework-bundle": "^7.4||^8.0",
        "symfony/http-kernel": "^7.4||^8.0",
        "symfony/routing": "^7.4||^8.0",
        "symfony/stimulus-bundle": "^2.0|^3.0",
        "symfony/twig-bundle": "^7.4||^8.0",
        "symfony/ux-twig-component": "^2.0|^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfinity/ui-kernel": "^0.2",
        "symfony/browser-kit": "^7.4||^8.0",
        "symfony/css-selector": "^7.4||^8.0",
        "symfony/form": "^7.4||^8.0",
        "symfony/security-csrf": "^7.4||^8.0",
        "symfony/validator": "^7.4||^8.0"
    },
    "autoload": {
        "psr-4": {
            "Symfinity\\PrivacySettingsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\PrivacySettingsBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "suggest": {
        "symfinity/ui-kernel": "Optional theme tokens and app shell styling for consent UI"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "symfony": {
            "require": "^7.4||^8.0"
        },
        "documentation": "https://github.com/symfinity/privacy-settings-bundle/tree/main/docs"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
